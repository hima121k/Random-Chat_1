rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if the authenticated user is an owner via the roles collection
    // Falls back to hardcoded emails to prevent bootstrap deadlock in new deployments.
    function isOwner() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/roles/$(request.auth.token.email)) &&
         get(/databases/$(database)/documents/roles/$(request.auth.token.email)).data.role == 'owner')
        ||
        request.auth.token.email in ['katarekrish7@gmail.com', 'himanshukatare54@gmail.com', 'katareh121@gmail.com']
      );
    }

    // Helper: check if the authenticated user is an owner OR admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/roles/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/roles/$(request.auth.token.email)).data.role in ['owner', 'admin'];
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.participants || isOwner()
      );
      allow write: if request.auth != null && (
        request.auth.uid in resource.data.participants ||
        (resource.data.status == 'waiting' && request.auth.uid in request.resource.data.participants) ||
        isOwner()
      );
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isOwner());
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && (
            (request.resource.data.keys().hasAll(['ct','iv','senderId','createdAt'])
              && request.resource.data.ct is string
              && request.resource.data.ct.size() <= 8000)
            ||
            (request.resource.data.keys().hasAll(['text','senderId','createdAt'])
              && request.resource.data.text is string
              && request.resource.data.text.size() <= 2000)
          );
        allow update, delete: if false;
      }

      match /e2eeKeys/{uid} {
        allow read: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isOwner());
        allow write: if request.auth != null
          && request.auth.uid == uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }

      match /callerCandidates/{candidateId} {
        allow read, write: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isOwner());
      }

      match /calleeCandidates/{candidateId} {
        allow read, write: if request.auth != null
          && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isOwner());
      }
    }

    match /waiting_room/{docId} {
      allow read, write: if request.auth != null;
    }

    match /banned_users/{userId} {
      allow read: if true;
      // Only owners/admins can write bans; auto-bans use the Admin SDK (Cloud Functions)
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    match /roles/{email} {
      allow read: if request.auth != null;
      allow write: if isOwner(); 
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /ban_appeals/{appealId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isOwner();
    }

    match /users/{userId} {
      // Allow any authenticated user to read profiles (needed for badges in chat)
      allow read: if request.auth != null;
      // Only the user or the Owner can edit a profile
      allow write: if request.auth != null && (request.auth.uid == userId || isOwner());
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /platform_metrics/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }
    
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
